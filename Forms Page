<!DOCTYPE html>
<html>
<head>
    <title>Interactive Form</title>
    <style>
        body { background: #009688; display: flex; justify-content: center; padding: 20px; font-family: sans-serif; }
        form { background: white; padding: 40px; border-radius: 10px; width: 400px; }
        input, select, textarea { width: 100%; padding: 8px; margin: 10px 0; border: 1px solid #ccc; border-radius: 5px; }
        input[type="submit"] { background: #009688; color: white; border: none; cursor: pointer; font-weight: bold; }
    </style>
</head>
<body>
    <form>
        <h2 style="color:#009688">User Access</h2>
        <input type="text" placeholder="Username" required>
        <input type="password" placeholder="Password" required>
        <label>Gender:</label>
        <input type="radio" name="g" style="width: auto;"> M 
        <input type="radio" name="g" style="width: auto;"> F <br>
        <label>Interests:</label>
        <input type="checkbox" style="width: auto;"> UI/UX 
        <input type="checkbox" style="width: auto;"> Dev <br>
        <select><option>Select Country</option><option>USA</option><option>India</option></select>
        <input type="file">
        <textarea placeholder="Your bio..."></textarea>
        <input type="submit" value="Launch">
        <input type="reset" value="Clear" style="background: #757575; color: white;">
        <p align="center"><a href="index.html">Home</a></p>
    </form>
</body>
</html>
