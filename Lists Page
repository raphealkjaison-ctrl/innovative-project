<!DOCTYPE html>
<html>
<head>
    <title>Structured Lists</title>
    <style>
        body { background: #f4f7f6; color: #333; padding: 50px; }
        .card { background: white; padding: 30px; border-radius: 15px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); max-width: 500px; margin: auto; }
        dt { font-weight: bold; color: #2c3e50; margin-top: 10px; }
    </style>
</head>
<body>
    <div class="card">
        <h2>List Categories</h2>
        <h3>Unordered Skills</h3>
        <ul><li>HTML5</li><li>CSS3</li><li>GitHub</li></ul>
        <h3>Ordered Progress</h3>
        <ol><li>Learn Tags</li><li>Style with CSS</li><li>Deploy to Web</li></ol>
        <h3>Vocabulary</h3>
        <dl>
            <dt>Frontend</dt><dd>What the user sees.</dd>
            <dt>Backend</dt><dd>The server-side logic.</dd>
        </dl>
        <a href="index.html">Back Home</a>
    </div>
</body>
</html>
